# Memory-Cortex configuration
# Copy to .env and fill in your values.

# === Core ===
CORTEX_DB_PATH=./data/cortex.db
BIND_HOST=127.0.0.1
PORT=7100
CORTEX_SECRET=changeme

# === LLM ===
# Two formats: anthropic (Anthropic Messages API) or openai (Chat Completions — everything else)
CORTEX_LLM_FORMAT=anthropic
CORTEX_LLM_URL=https://api.anthropic.com/v1/messages
CORTEX_LLM_KEY=sk-ant-...

# OpenRouter example:
# CORTEX_LLM_FORMAT=openai
# CORTEX_LLM_URL=https://openrouter.ai/api/v1/chat/completions
# CORTEX_LLM_KEY=sk-or-...

# Kimi example:
# CORTEX_LLM_FORMAT=openai
# CORTEX_LLM_URL=https://api.moonshot.cn/v1/chat/completions
# CORTEX_LLM_KEY=sk-...

# Local Ollama example:
# CORTEX_LLM_FORMAT=openai
# CORTEX_LLM_URL=http://127.0.0.1:11434/v1/chat/completions
# CORTEX_LLM_KEY=ollama

# === Models ===
# Worker: consolidation, compaction (cheap, fast)
# Judge: contradiction detection, L3 crystallization (accurate)
# CORTEX_WORKER_MODEL=claude-haiku-4-5-20251001
# CORTEX_JUDGE_MODEL=claude-sonnet-4-6

# === Agent ===
CORTEX_DEFAULT_AGENT=default

# === Croner (all off by default) ===
# CRONER_ENABLED=true
# CRON_L0L1=true
# CRON_L1L2=true
# CRON_L2L3=true
# CRON_CONTRADICTION=true
# CRON_MAINTENANCE=true
# CRON_L0_RETENTION=true
# CRON_ENTITY_QUEUE=true

# === Telegram notifications (optional) ===
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_HOME_CHANNEL=

# === Cognitive layer (optional) ===
# METAMEMORY_ENABLED=true
